<template>
  <view class="ai-assistant-page">
    <!-- 顶部导航栏 -->
    <view class="nav-bar">
      <view class="nav-back" @click="goBack">‹</view>
      <text class="nav-title">AI助教</text>
      <view class="nav-right"></view>
    </view>

    <!-- 模式切换Tab -->
    <view class="mode-tabs">
      <view 
        class="tab-item" 
        :class="{active: currentMode === 'chat'}"
        @click="switchMode('chat')">
        对话模式
      </view>
      <view 
        class="tab-item" 
        :class="{active: currentMode === 'correct'}"
        @click="switchMode('correct')">
        作业批改
      </view>
    </view>

    <!-- 聊天历史区域 -->
    <scroll-view 
      scroll-y 
      class="chat-scroll"
      :scroll-into-view="scrollToId"
      scroll-with-animation>
      <view class="message-list">
        <view 
          class="message-item" 
          v-for="(msg, index) in messageList" 
          :key="msg.id"
          :id="'msg-' + index"
          :class="msg.role === 'user' ? 'msg-right' : 'msg-left'">
          <!-- AI头像 -->
          <view v-if="msg.role === 'ai'" class="avatar ai-avatar">AI</view>
          <!-- 消息内容 -->
          <view class="msg-content">
            <text v-if="msg.type === 'text'" class="msg-text">{{ msg.content }}</text>
            <image v-if="msg.type === 'image'" :src="msg.content" class="msg-image" mode="widthFix" @click="previewImage(msg.content)"/>
          </view>
          <!-- 用户头像 -->
          <view v-if="msg.role === 'user'" class="avatar user-avatar">我</view>
        </view>

        <!-- AI加载中 -->
        <view v-if="isLoading" class="message-item msg-left" id="msg-loading">
          <view class="avatar ai-avatar">AI</view>
          <view class="msg-content">
            <text class="msg-text">正在思考中...</text>
          </view>
        </view>
        <view class="chat-bottom-space"></view>
      </view>
    </scroll-view>

    <!-- 底部输入区域 -->
    <view class="input-footer">
      <!-- 对话模式 -->
      <template v-if="currentMode === 'chat'">
        <view class="chat-input-row">
          <input 
            class="text-input" 
            v-model="inputText" 
            placeholder="请输入你的问题"
            confirm-type="send"
            @confirm="sendTextMessage"/>
          <view 
            class="send-btn" 
            :class="{disabled: !inputText.trim()}"
            @click="sendTextMessage">
            发送
          </view>
        </view>
      </template>

      <!-- 作业批改模式 -->
      <template v-else>
        <view class="correct-input-area">
          <view v-if="selectedImage" class="image-preview-wrap">
            <image :src="selectedImage" class="preview-image" mode="aspectFill"/>
            <view class="delete-image" @click="clearImage">×</view>
          </view>
          <view class="correct-bottom-row">
            <view class="correct-actions">
              <view class="action-item" @click="chooseImage('camera')">
                <text class="action-icon">📷</text>
                <text class="action-text">拍照</text>
              </view>
              <view class="action-item" @click="chooseImage('album')">
                <text class="action-icon">🖼️</text>
                <text class="action-text">相册</text>
              </view>
            </view>
            <view 
              class="send-btn correct-send-btn"
              :class="{disabled: !selectedImage}"
              @click="sendCorrectMessage">
              提交批改
            </view>
          </view>
        </view>
      </template>
    </view>
  </view>
</template>

<script setup lang="uts">
import { ref, nextTick } from 'vue'

interface MessageItem {
  id: number
  role: string
  type: string
  content: string
  time: string
}

const currentMode = ref<string>('chat')
const inputText = ref<string>('')
const selectedImage = ref<string>('')
const isLoading = ref<boolean>(false)
const scrollToId = ref<string>('')
let msgIdCounter = 2

const messageList = ref<MessageItem[]>([
  {
    id: 1,
    role: 'ai',
    type: 'text',
    content: '你好，我是AI助教，有什么问题都可以问我哦~',
    time: getCurrentTime()
  }
])

function getCurrentTime(): string {
  const date = new Date()
  const h = String(date.getHours()).padStart(2, '0')
  const m = String(date.getMinutes()).padStart(2, '0')
  return `${h}:${m}`
}

function goBack(): void {
  uni.navigateBack()
}

function scrollToBottom(): void {
  nextTick(() => {
    scrollToId.value = isLoading.value ? 'msg-loading' : `msg-${messageList.value.length - 1}`
  })
}

function addMessage(role: string, type: string, content: string): void {
  messageList.value.push({
    id: msgIdCounter++,
    role,
    type,
    content,
    time: getCurrentTime()
  })
}

function previewImage(src: string): void {
  uni.previewImage({ urls: [src], current: src })
}

function switchMode(mode: string): void {
  if (currentMode.value === mode || isLoading.value) return
  currentMode.value = mode
  inputText.value = ''
  selectedImage.value = ''
}

function sendTextMessage(): void {
  const text = inputText.value.trim()
  if (!text || isLoading.value) return

  addMessage('user', 'text', text)
  inputText.value = ''
  isLoading.value = true
  scrollToBottom()
  requestChatApi(text)
}

function requestChatApi(question: string): void {
  setTimeout(() => {
    addMessage('ai', 'text', `这是针对「${question}」的模拟回答，对接正式接口后会返回真实AI回复内容。`)
    isLoading.value = false
    scrollToBottom()
  }, 1000)
}

function chooseImage(type: string): void {
  const sourceType = type === 'camera' ? ['camera'] : ['album']
  uni.chooseImage({
    count: 1,
    sourceType: sourceType,
    sizeType: ['compressed'],
    success: (res: any) => {
      convertImageToBase64(res.tempFilePaths[0])
    },
    fail: () => {
      uni.showToast({ title: '选择图片失败', icon: 'none' })
    }
  })
}

function convertImageToBase64(filePath: string): void {
  uni.getFileSystemManager().readFile({
    filePath: filePath,
    encoding: 'base64',
    success: (res: any) => {
      selectedImage.value = `data:image/jpeg;base64,${res.data}`
    },
    fail: () => {
      uni.showToast({ title: '图片处理失败', icon: 'none' })
    }
  })
}

function clearImage(): void {
  selectedImage.value = ''
}

function sendCorrectMessage(): void {
  if (!selectedImage.value || isLoading.value) return

  addMessage('user', 'image', selectedImage.value)
  const imageBase64 = selectedImage.value
  selectedImage.value = ''
  isLoading.value = true
  scrollToBottom()

  setTimeout(() => {
    const mockResult = `【作业批改结果】
1. 第2题计算错误：
   错误原因：乘法分配律应用错误，漏乘常数项
   正确思路：3×(x+2) = 3x + 6，而非3x+2

2. 第5题单位错误：
   错误原因：最终结果未换算成题目要求的平方米单位
   正确思路：先统一单位计算，最终结果换算后为24.5㎡

整体正确率75%，继续加油哦~`
    addMessage('ai', 'text', mockResult)
    isLoading.value = false
    scrollToBottom()
  }, 1500)
}
</script>

<style scoped>
