}

/* 消息气泡 核心修复 */
.msg-content {
  max-width: calc(100% - 80rpx); /* 减去头像+间距宽度 */
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  line-height: 1.6;
  box-sizing: border-box;
  word-wrap: break-word;
  word-break: break-all;
  overflow-wrap: break-word;
