.scroll-content {
  height: calc(100vh - env(safe-area-inset-top) - 60px);
}

/* Banner */
.banner-section {
  padding: 16px 16px 0;
}
.banner-swiper {
  height: 180px;
  border-radius: 16px;
  overflow: hidden;
}
.banner-default {
  height: 180px;
  border-radius: 16px;
  overflow: hidden;
  background: linear-gradient(135deg, #4A90D9 0%, #6BB5FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}
.banner-default-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.banner-default-title {
  font-size: 20px;
  font-weight: 600;
  color: #FFFFFF;
}
.banner-default-desc {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
}
