  background: rgba(255, 255, 255, 0.25);
  border-radius: 22px;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 16px;
  gap: 8px;
}
.search-icon {
  font-size: 18px;
  color: rgba(255, 255, 255, 0.9);
  flex-shrink: 0;
}
.search-placeholder {
  font-size: 15px;
  color: rgba(255, 255, 255, 0.8);
}

