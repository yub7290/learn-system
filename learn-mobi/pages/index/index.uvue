  width: 100%;
  height: 180px;
  border-radius: 16px;
}

/* 功能导航 */
.nav-section {
  padding: 16px;
}
.nav-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 12px;
  padding: 20px 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
