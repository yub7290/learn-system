<template>
  <view class="home">
    <!-- 自定义导航栏 -->
    <view class="navbar">
      <view class="navbar-content">
        <image class="navbar-logo" src="/static/logo.png" mode="aspectFit"></image>
        <view class="navbar-search" @click="goSearch">
          <text class="iconfont search-icon">&#xe634;</text>
          <text class="search-placeholder">搜索课程、教师</text>
        </view>
      </view>
    </view>

    <scroll-view scroll-y class="scroll-content" @scrolltolower="loadMore">
      <!-- Banner 轮播 -->
      <view class="banner-section">
        <swiper class="banner-swiper" :indicator-dots="true" :autoplay="true" :interval="3000" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#FFFFFF" v-if="bannerList.length > 0">
          <swiper-item v-for="(item, index) in bannerList" :key="index" @click="goLink(item.link)">
            <image class="banner-img" :src="item.img" mode="aspectFill"></image>
          </swiper-item>
        </swiper>
        <!-- 默认 Banner -->
        <view class="banner-default" v-else>
          <view class="banner-default-content">
            <text class="banner-default-title">欢迎来到学习平台</text>
            <text class="banner-default-desc">开启你的学习之旅</text>
          </view>
        </view>
      </view>

      <!-- 功能导航 -->
      <view class="nav-section">
        <view class="nav-grid">
          <view class="nav-item" v-for="(item, index) in navList" :key="index" @click="goLink(item.link)">
            <view class="nav-icon-wrap" :style="{ background: item.bgColor }">
              <text class="iconfont nav-icon">{{ item.iconCode }}</text>
            </view>
            <text class="nav-name">{{ item.name }}</text>
          </view>
        </view>
      </view>

      <!-- 推荐教师 -->
      <view class="section" v-if="teacherList.length > 0">
        <view class="section-header">
          <text class="section-title">名师推荐</text>
          <view class="section-more" @click="goTeacherList">
            <text class="more-text">查看全部</text>
            <text class="css-icon-arrow-right"></text>
          </view>
        </view>
        <scroll-view scroll-x class="teacher-scroll">
          <view class="teacher-list">
            <view class="teacher-card" v-for="(item, index) in teacherList" :key="index" @click="goTeacherHome(item.id)">
              <image class="teacher-avatar" :src="item.avatar || '/static/logo.png'" mode="aspectFill"></image>
              <text class="teacher-name">{{ item.name }}</text>
              <text class="teacher-title">{{ item.title || '讲师' }}</text>
            </view>
            <view class="teacher-spacer"></view>
          </view>
        </scroll-view>
      </view>

      <!-- 精选课程 -->
      <view class="section">
        <view class="section-header">
          <text class="section-title">精选课程</text>
          <view class="section-more" @click="goCourseList">
            <text class="more-text">查看全部</text>
            <text class="css-icon-arrow-right"></text>
          </view>
        </view>
        <view class="course-grid" v-if="courseList.length > 0">
          <course-card
            v-for="item in courseList"
            :key="item.id"
            :img="item.img"
            :name="item.name"
            :link="item.link"
            :type="item.type"
            @click="goLink"
          ></course-card>
        </view>
        <view class="empty-state" v-else-if="!loading">
          <text class="iconfont empty-icon">&#xe62c;</text>
          <text class="empty-text">暂无课程</text>
          <text class="empty-hint" @click="goCourseList">去课程中心探索</text>
        </view>
      </view>

      <view class="safe-bottom"></view>
    </scroll-view>
  </view>
</template>

<script lang="uts">
const BASE_URL = 'http://localhost:8001/api'

export default {
  data() {
    return {
      searchVal: "",
      logoUrl: "/static/logo.png",
      bannerList: [] as Array<any>,
      navList: [
        { name: "全部课程", iconCode: "\ue62c", bgColor: "#EBF5FF", link: "/pages/course/course" },
        { name: "在线考试", iconCode: "\ue623", bgColor: "#FEF3C7", link: "/pages/exam/exam" },
        { name: "我的学习", iconCode: "\ue62f", bgColor: "#DCFCE7", link: "/pages/mine/mine" },
        { name: "名师风采", iconCode: "\ue60f", bgColor: "#FCE7F3", link: "" }
      ],
      teacherList: [] as Array<any>,
      courseList: [] as Array<any>,
      loading: false
    }
  },
  onShow() {
    this.getBaseData()
  },
  methods: {
    getBaseData() {
      this.loading = true
      const token = uni.getStorageSync('access_token') || ''
      const header = { 'Content-Type': 'application/json' }
      if (token != null && token !== '') {
        header['Authorization'] = 'Bearer ' + token
      }

      uni.request({
        url: BASE_URL + '/student/home/base',
        method: 'GET',
        header: header,
        success: (res) => {
          const r = res as any
          if (r.statusCode === 200 && r.data.code === 200) {
            this.logoUrl = r.data.data.logo || '/static/logo.png'
            this.bannerList = r.data.data.banner || []
          }
        },
        fail: () => {}
      })

      uni.request({
        url: BASE_URL + '/student/home/teacher',
        method: 'GET',
        header: header,
        success: (res) => {
          const r = res as any
          if (r.statusCode === 200 && r.data.code === 200) {
            this.teacherList = r.data.data.list || []
          }
        },
        fail: () => {}
      })

      uni.request({
        url: BASE_URL + '/student/home/course',
        method: 'GET',
        header: header,
        success: (res) => {
          const r = res as any
          if (r.statusCode === 200 && r.data.code === 200) {
            this.courseList = r.data.data.list || []
          }
        },
        fail: () => {},
        complete: () => { this.loading = false }
      })
    },
    goSearch() {
      uni.navigateTo({ url: '/pages/course/course' })
    },
    goLink(url) {
      if (!url || url.length === 0) return
      uni.navigateTo({ url: url })
    },
    goTeacherList() {},
    goTeacherHome(teacherId) {
      uni.navigateTo({ url: '/pages/teacher/teacher?tid=' + teacherId })
    },
    goCourseList() {
      uni.switchTab({ url: '/pages/course/course' })
    },
    loadMore() {}
  }
}
</script>

<style scoped>
.home {
  min-height: 100vh;
  background: #F5F7FA;
}

