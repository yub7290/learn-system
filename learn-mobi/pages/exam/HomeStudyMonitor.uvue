<template>
  <view class="monitor-page">
    <!-- 自定义导航栏 -->
    <view class="navbar">
      <view class="navbar-content">
        <view class="back-btn" @click="goBack">
          <text class="css-icon-back" style="color: #FFFFFF;"></text>
        </view>
        <text class="navbar-title">在线考试监考</text>
        <view class="navbar-right">
          <text class="status-text" v-if="isRunning">监考中</text>
        </view>
      </view>
    </view>

    <!-- 摄像头区域 -->
    <view class="camera-container">
      <!-- #ifdef APP-PLUS -->
      <camera class="camera" device-position="front" flash="off"></camera>
      <!-- #endif -->
    </view>

    <!-- 考试信息 -->
    <view class="exam-info" v-if="examInfo != null">
      <view class="info-row">
        <text class="info-label">考试名称</text>
        <text class="info-value">{{ examInfo.name }}</text>
      </view>
      <view class="info-row">
        <text class="info-label">剩余时间</text>
        <text class="info-value countdown">{{ remainingTime }}</text>
      </view>
    </view>

    <!-- 行为监测 -->
    <view class="stats-section" v-if="isRunning">
      <text class="stats-title">行为监测</text>
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-num">{{ abnormalCount }}</text>
          <text class="stat-label">异常次数</text>
        </view>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="btn-bar">
      <view 
        class="btn-item" 
        :class="isRunning ? 'btn-running' : 'btn-start'" 
        @click="isRunning ? stopByFinish() : startMonitor()"
      >
        <text class="btn-text">{{ isRunning ? '完成考试' : '开始考试' }}</text>
      </view>
      <view class="btn-item btn-terminate" v-if="isRunning" @click="stopByTerminate">
        <text class="btn-text">终止考试</text>
      </view>
      <view class="btn-item btn-exit" v-if="!isRunning" @click="exitPage">
        <text class="btn-text">退出</text>
      </view>
    </view>
  </view>
</template>

<script lang="uts">
const BASE_URL = 'http://localhost:8001/api'

export default {
  data() {
    return {
      examId: 0,
      examInfo: null as any,
      isRunning: false,
      startTime: 0,
      remainingTime: '00:00:00',
      countdownTimer: null as any,
      abnormalCount: 0,
      detectTimer: null as any
    }
  },
  onLoad(option) {
    this.examId = Number(option.examId) || 0
    if (this.examId === 0) {
      uni.showToast({ title: '参数错误', icon: 'none' })
      setTimeout(() => { uni.navigateBack() }, 1500)
      return
    }
    this.loadExamInfo()
  },
  onUnload() { this.cleanupResources() },
  methods: {
    loadExamInfo() {
      uni.request({
        url: BASE_URL + '/student/exam/info/' + this.examId,
        method: 'GET',
        success: (res) => {
          const r = res as any
          if (r.statusCode === 200 && r.data.code === 200) {
            this.examInfo = r.data.data
          }
          this.initCountdown()
        },
        fail: () => {
          this.examInfo = { id: this.examId, name: '在线考试', endTime: new Date(Date.now() + 120 * 60 * 1000).toISOString() }
          this.initCountdown()
        }
      })
    },
    initCountdown() {
      if (this.examInfo == null) return
      const endTime = new Date(this.examInfo.endTime).getTime()
      this.countdownTimer = setInterval(() => {
        const diff = endTime - Date.now()
        if (diff <= 0) { this.remainingTime = '00:00:00'; clearInterval(this.countdownTimer); return }
        const h = Math.floor(diff / 3600000)
        const m = Math.floor((diff % 3600000) / 60000)
        const s = Math.floor((diff % 60000) / 1000)
        this.remainingTime = String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0')
      }, 1000)
    },
    startMonitor() {
      this.isRunning = true
      this.startTime = Date.now()
      this.detectTimer = setInterval(() => { if (Math.random() < 0.1) this.abnormalCount++ }, 3000)
      uni.showToast({ title: '监考已开始', icon: 'success' })
    },
    stopByTerminate() {
      uni.showModal({ title: '确认终止', content: '确定要终止考试吗？终止后将无法继续答题。', success: (res) => { const r = res as any; if (r.confirm) this.endExam('terminate') } })
    },
    stopByFinish() {
      uni.showModal({ title: '确认提交', content: '确定要提交考试吗？', success: (res) => { const r = res as any; if (r.confirm) this.endExam('finish') } })
    },
    endExam(type) {
      this.cleanupResources()
      const duration = this.startTime > 0 ? Math.floor((Date.now() - this.startTime) / 1000) : 0
      uni.request({ url: BASE_URL + '/student/exam/result/submit', method: 'POST', data: { examId: this.examId, endType: type, duration: duration } })
      uni.showToast({ title: '考试已提交', icon: 'success' })
      setTimeout(() => { uni.navigateBack() }, 1500)
    },
    exitPage() { this.isRunning ? this.stopByTerminate() : uni.navigateBack() },
    cleanupResources() {
      this.isRunning = false
      if (this.countdownTimer != null) { clearInterval(this.countdownTimer); this.countdownTimer = null }
      if (this.detectTimer != null) { clearInterval(this.detectTimer); this.detectTimer = null }
    },
    goBack() {
      if (this.isRunning) { uni.showModal({ title: '提示', content: '考试正在进行中，确定要退出吗？', success: (res) => { const r = res as any; if (r.confirm) this.stopByTerminate() } }) }
      else { uni.navigateBack() }
    }
  }
}
</script>

<style scoped>
