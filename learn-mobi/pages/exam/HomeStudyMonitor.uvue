  display: flex;
  align-items: center;
  margin-bottom: 12px;
}
.info-row:last-child {
  margin-bottom: 0;
}
.info-label {
  font-size: 14px;
  color: #64748B;
  width: 80px;
  flex-shrink: 0;
}
.info-value {
  font-size: 14px;
  color: #1E293B;
  flex: 1;
  font-weight: 500;
}
.countdown {
  font-size: 24px;
  font-weight: 700;
  color: #EF4444;
  font-variant-numeric: tabular-nums;
}

/* 行为监测 */
.stats-section {
  background: #FFFFFF;
  margin: 0 16px 16px;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}
.stats-title {
  font-size: 16px;
  font-weight: 600;
  color: #1E293B;
  display: block;
  margin-bottom: 12px;
}
.stats-grid {
  display: flex;
}
.stat-item {
  flex: 1;
  text-align: center;
  background: #F8FAFC;
  border-radius: 12px;
  padding: 16px;
}
.stat-num {
  font-size: 28px;
  font-weight: 700;
  color: #4A90D9;
  display: block;
  margin-bottom: 4px;
  font-variant-numeric: tabular-nums;
}
.stat-label {
  font-size: 12px;
  color: #64748B;
}

/* 底部按钮 */
.btn-bar {
  padding: 16px;
  display: flex;
  gap: 12px;
  background: #FFFFFF;
  border-top: 1px solid #F1F5F9;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.04);
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
}
.btn-item {
  flex: 1;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease;
}
.btn-item:active {
  transform: scale(0.97);
}
.btn-start {
  background: linear-gradient(135deg, #4A90D9 0%, #6BB5FF 100%);
}
